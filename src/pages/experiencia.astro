---
import Layout from '../Layout.astro';
import '../styles/global.css';
---

<Layout>
  <section class="relative isolate overflow-hidden pt-24 pb-16 px-4 sm:pt-28">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute -top-12 -left-16 h-72 w-72 rounded-full bg-primary/10 blur-3xl"
      >
      </div>
      <div
        class="absolute -bottom-16 -right-12 h-80 w-80 rounded-full bg-secondary/10 blur-3xl"
      >
      </div>
    </div>

    <div class="mx-auto max-w-5xl space-y-8">
      <header class="card bg-base-100 shadow-md border border-base-300 rounded-2xl p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-base-content/60">
          Perfil profesional
        </p>
        <h1 class="mt-2 text-3xl md:text-4xl font-bold leading-tight text-base-content">
          Experiencia en desarrollo, datos y automatizacion de procesos
        </h1>
        <p class="mt-3 max-w-3xl text-base-content">
          Ingeniero Civil en Informatica con experiencia en desarrollo full stack y trabajo con
          datos, enfocado en construir soluciones practicas, reproducibles y orientadas a impacto.
        </p>

        <div class="mt-5 flex flex-wrap gap-2">
          <span
            class="badge badge-info badge-outline text-xs font-medium"
          >
            Python + Django
          </span>
          <span
            class="badge badge-success badge-outline text-xs font-medium"
          >
            SQL + PostgreSQL
          </span>
          <span
            class="badge badge-accent badge-outline text-xs font-medium"
          >
            ETL + NLP
          </span>
          <span
            class="badge badge-warning badge-outline text-xs font-medium"
          >
            Power BI + reporting
          </span>
        </div>
      </header>

      <article class="grid gap-6 lg:grid-cols-[300px_1fr]">
        <aside class="space-y-4 lg:sticky lg:top-28 lg:self-start">
          <section class="card bg-base-100 shadow-md border border-base-300 rounded-2xl p-5">
            <h2 class="text-lg font-semibold text-base-content">Educacion</h2>
            <p class="mt-3 text-sm font-medium text-base-content">
              Ingeniero Civil en Informatica
            </p>
            <p class="text-sm text-base-content">
              Universidad Austral de Chile, Valdivia
            </p>
            <span
              class="badge badge-info badge-outline text-xs font-bold"
            >
              Titulado 2023
            </span>
          </section>

          <section class="card bg-base-100 shadow-md border border-base-300 rounded-2xl p-5">
            <h2 class="text-lg font-semibold text-base-content">Stack principal</h2>
            <ul class="mt-3 space-y-2 text-sm text-base-content">
              <li>Python, Django, APIs REST</li>
              <li>SQL, PostgreSQL, modelado de datos</li>
              <li>pandas, NumPy, scikit-learn</li>
              <li>Power BI y visualizacion ejecutiva</li>
            </ul>
          </section>
        </aside>

        <section class="card bg-base-100 shadow-md border border-base-300 rounded-2xl p-5">
          <h2 class="text-xl font-semibold text-base-content">Experiencia laboral</h2>

          <ol class="mt-6 border-s-2 border-base-300 ps-6 space-y-6">
            <li class="relative">
              <span
                class="absolute -start-[1.92rem] top-1.5 h-3.5 w-3.5 rounded-full border-2 border-base-100 bg-cyan-500 shadow"
              ></span>
              <article class="card bg-base-100 shadow-md border border-base-300 rounded-xl p-4">
                <p
                  class="text-xs font-semibold uppercase tracking-wider text-info"
                >
                  nov. 2024 - Actualidad
                </p>
                <h3 class="mt-1 text-lg font-semibold text-base-content">
                  Ingeniero de Desarrollo - Innovex SpA, Valdivia
                </h3>
                <ul class="mt-3 list-disc pl-5 text-sm text-base-content space-y-1">
                  <li>Construccion de APIs y pipelines de datos con Django y Python.</li>
                  <li>Integracion de bases de datos relacionales con PostgreSQL y SQL.</li>
                  <li>Validacion, limpieza y transformacion de datos para procesos de negocio.</li>
                  <li>
                    Trabajo interdisciplinario con producto y QA, incluyendo documentacion tecnica.
                  </li>
                </ul>
              </article>
            </li>

            <li class="relative">
              <span
                class="absolute -start-[1.92rem] top-1.5 h-3.5 w-3.5 rounded-full border-2 border-base-100 bg-fuchsia-500 shadow"
              ></span>
              <article class="card bg-base-100 shadow-md border border-base-300 rounded-xl p-4">
                <p
                  class="text-xs font-semibold uppercase tracking-wider text-secondary"
                >
                  sep. 2023 - jun. 2024
                </p>
                <h3 class="mt-1 text-lg font-semibold text-base-content">
                  Analista de Datos y Optimizacion de Procesos - EQUANS, Osorno
                </h3>
                <ul class="mt-3 list-disc pl-5 text-sm text-base-content space-y-1">
                  <li>EDA para optimizacion de rutas y eficiencia de cuadrillas operativas.</li>
                  <li>
                    Preparacion de datasets con SQL y Python: limpieza, normalizacion y features.
                  </li>
                  <li>Diseno de dashboards y reportes en Power BI para jefaturas no tecnicas.</li>
                  <li>Analisis estadistico para detectar patrones y oportunidades de mejora.</li>
                  <li>Implementacion de sistema de trazabilidad integrando multiples fuentes.</li>
                </ul>
              </article>
            </li>

            <li class="relative">
              <span
                class="absolute -start-[1.92rem] top-1.5 h-3.5 w-3.5 rounded-full border-2 border-base-100 bg-emerald-500 shadow"
              ></span>
              <article class="card bg-base-100 shadow-md border border-base-300 rounded-xl p-4">
                <p
                  class="text-xs font-semibold uppercase tracking-wider text-success"
                >
                  ene. 2021 - sep. 2023
                </p>
                <h3 class="mt-1 text-lg font-semibold text-base-content">
                  Colaborador y Tesista - SOPHIA, Valdivia
                </h3>
                <ul class="mt-3 list-disc pl-5 text-sm text-base-content space-y-1">
                  <li>
                    Pipelines ETL para extraccion y estructuracion de datos desde PDFs y scraping.
                  </li>
                  <li>Modelos de NLP con Python para clasificacion y analisis de textos.</li>
                  <li>Entrenamiento de modelos con pandas, NumPy y scikit-learn.</li>
                  <li>Automatizacion de reportes con visualizaciones y metricas claras.</li>
                  <li>Diseno de scripts reproducibles y documentados para datasets extensos.</li>
                </ul>
              </article>
            </li>

            <li class="relative">
              <span
                class="absolute -start-[1.92rem] top-1.5 h-3.5 w-3.5 rounded-full border-2 border-base-100 bg-amber-500 shadow"
              ></span>
              <article class="card bg-base-100 shadow-md border border-base-300 rounded-xl p-4">
                <p
                  class="text-xs font-semibold uppercase tracking-wider text-warning"
                >
                  ene. 2019 - feb. 2019
                </p>
                <h3 class="mt-1 text-lg font-semibold text-base-content">
                  Encargado de Trazabilidad - Framberry, Osorno
                </h3>
                <ul class="mt-3 list-disc pl-5 text-sm text-base-content space-y-1">
                  <li>
                    Administracion del sistema de trazabilidad implementado en la organizacion.
                  </li>
                  <li>Capacitacion de equipos sobre operatividad y flujos de uso.</li>
                  <li>Propuestas de mejora para optimizacion de la gestion del sistema.</li>
                </ul>
              </article>
            </li>
          </ol>
        </section>
      </article>

      <section class="card bg-base-100 shadow-md border border-base-300 rounded-2xl p-6">
        <h2 class="text-xl font-semibold text-base-content">
          Actividades extracurriculares
        </h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          <article class="card bg-base-100 shadow-md border border-base-300 rounded-xl p-4">
            <p
              class="text-xs font-semibold uppercase tracking-wider text-base-content/70"
            >
              jul. 2020 - jul. 2023
            </p>
            <h3 class="mt-1 text-base font-semibold text-base-content">
              Ayudante y Laborante de Programacion - UACh
            </h3>
            <ul class="mt-3 list-disc pl-5 text-sm text-base-content space-y-1">
              <li>Coordinacion de clases practicas de Python para carreras de Ingenieria.</li>
              <li>Diseno de recursos didacticos y mejora de metodologias de ensenanza.</li>
            </ul>
          </article>

          <article class="card bg-base-100 shadow-md border border-base-300 rounded-xl p-4">
            <p
              class="text-xs font-semibold uppercase tracking-wider text-base-content/70"
            >
              abr. 2019 - abr. 2020
            </p>
            <h3 class="mt-1 text-base font-semibold text-base-content">
              Presidente del Centro de Estudiantes - UACh
            </h3>
            <ul class="mt-3 list-disc pl-5 text-sm text-base-content space-y-1">
              <li>Coordinacion entre estudiantes, profesores y decanatura.</li>
              <li>Impulso de mejoras en calidad educativa e infraestructura academica.</li>
            </ul>
          </article>
        </div>
      </section>
    </div>
  </section>
</Layout>
