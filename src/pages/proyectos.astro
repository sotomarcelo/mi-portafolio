---
import Layout from '../Layout.astro';
import '../styles/global.css';

const featured = [
  {
    title: 'P.U.L.S.O — Monitoreo de Sensores',
    stack: ['Django', 'DRF', 'PostgreSQL', 'WebSockets'],
    description:
      'Backend de la Plataforma de Uso Libre de Sensores Operativos. Desarrollo de API REST en Django para ingesta, procesamiento y consulta de datos de sensores en tiempo real. Apoyo en ideas de UX para el frontend.',
    status: 'En produccion',
    url: 'http://tenten.innovex.cl:3001/',
    imageLight: '/dashboard_pulso_claro.png',
    imageDark: '/dashboard_pulso_oscuro.png',
  },
  {
    title: 'Pasaporte del Cafe',
    stack: ['Next.js', 'Django', 'DRF', 'Tailwind', 'Leaflet', 'PostgreSQL'],
    description:
      'Plataforma colaborativa para evaluar la calidad de cafes de especialidad. Registro de granos, variedades, metodos de preparacion y valoraciones de la comunidad. Proyecto propio orientado a construir una red de entusiastas del cafe.',
    status: 'En desarrollo',
    imageLight: '/pasaporte_del_cafe.png',
    imageDark: '/pasaporte_del_cafe.png',
  },
];

const other = [
  {
    title: 'Pipeline de Datos para Operaciones',
    stack: ['Python', 'SQL', 'PostgreSQL'],
    description:
      'Automatizacion de flujo de datos desde fuentes operativas hasta tablas consolidadas para analisis y reporting.',
    status: 'Implementado',
    icon: 'data',
  },
  {
    title: 'API de Integracion en Django',
    stack: ['Django', 'DRF', 'PostgreSQL'],
    description:
      'Diseno de endpoints para integrar datos entre sistemas internos y servicios externos con validaciones robustas.',
    status: 'En produccion',
    icon: 'api',
  },
  {
    title: 'Dashboard de Indicadores Operativos',
    stack: ['Power BI', 'SQL', 'Python'],
    description:
      'Diseno de indicadores y paneles ejecutivos para seguimiento semanal de eficiencia, tiempos y calidad operativa.',
    status: 'Activo',
    icon: 'chart',
  },
];

const statusColor: Record<string, string> = {
  'En produccion': 'badge-success',
  'En desarrollo': 'badge-warning',
  Implementado: 'badge-info',
  Activo: 'badge-success',
};
---

<Layout>
  <section class="relative isolate overflow-hidden pt-24 pb-16 px-4 sm:pt-28">
    <!-- Background blobs -->
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-12 -left-16 h-72 w-72 rounded-full bg-success/10 blur-3xl"></div>
      <div class="absolute -bottom-16 -right-12 h-80 w-80 rounded-full bg-primary/10 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-5xl space-y-10">
      <!-- Header -->
      <header class="text-center sm:text-left">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">Portafolio</p>
        <h1 class="mt-2 text-3xl sm:text-4xl font-bold leading-tight text-base-content">
          Proyectos destacados
        </h1>
        <p class="mt-3 max-w-2xl text-base-content/70 text-sm sm:text-base">
          Seleccion de proyectos enfocados en integracion de datos, desarrollo backend y
          visualizacion para toma de decisiones.
        </p>
      </header>

      <!-- Featured projects: larger cards with images -->
      <div class="grid gap-6 sm:grid-cols-2">
        {
          featured.map((project) => (
            <article class="card bg-base-100 shadow-lg border border-base-300 overflow-hidden group">
              <figure class="relative h-48 sm:h-56 overflow-hidden">
                <img
                  src={project.imageLight}
                  alt={project.title}
                  class="w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-105 img-light"
                  loading="lazy"
                />
                <img
                  src={project.imageDark}
                  alt={project.title}
                  class="w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-105 img-dark"
                  loading="lazy"
                />
                <div class="absolute top-3 left-3">
                  <span class={`badge ${statusColor[project.status] || 'badge-ghost'} badge-sm font-semibold`}>
                    {project.status}
                  </span>
                </div>
              </figure>
              <div class="card-body p-5 gap-3">
                <h2 class="card-title text-base sm:text-lg text-base-content">{project.title}</h2>
                <p class="text-sm text-base-content/70 leading-relaxed">{project.description}</p>
                <div class="flex flex-wrap gap-1.5 mt-1">
                  {project.stack.map((tech) => (
                    <span class="badge badge-outline badge-sm text-xs">{tech}</span>
                  ))}
                </div>
                {project.url && (
                  <div class="card-actions mt-auto pt-2">
                    <a
                      href={project.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-primary btn-sm gap-1.5"
                    >
                      Ver proyecto
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h7a1 1 0 010 2H5v10h10v-6a1 1 0 112 0v7a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm11-1a1 1 0 000 2h1.586l-4.293 4.293a1 1 0 001.414 1.414L17 6.414V8a1 1 0 102 0V4a1 1 0 00-1-1h-4z" clip-rule="evenodd" />
                      </svg>
                    </a>
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </div>

      <!-- Other projects: compact list -->
      <div>
        <h2 class="text-lg font-semibold text-base-content mb-4">Otros proyectos</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            other.map((project) => (
              <article class="card bg-base-100 shadow-md border border-base-300 p-5 flex flex-col gap-3 transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-lg">
                <div class="flex items-center justify-between gap-2">
                  <span class={`badge ${statusColor[project.status] || 'badge-ghost'} badge-sm font-semibold`}>
                    {project.status}
                  </span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-base-content/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" />
                  </svg>
                </div>
                <h3 class="text-base font-semibold text-base-content leading-snug">{project.title}</h3>
                <p class="text-sm text-base-content/70 leading-relaxed flex-1">{project.description}</p>
                <div class="flex flex-wrap gap-1.5 mt-auto pt-1">
                  {project.stack.map((tech) => (
                    <span class="badge badge-outline badge-sm text-xs">{tech}</span>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
