---
import Layout from '../Layout.astro';
import '../styles/global.css';

const projects = [
  {
    title: 'Pipeline de Datos para Operaciones',
    stack: 'Python, SQL, PostgreSQL',
    description:
      'Automatizacion de flujo de datos desde fuentes operativas hasta tablas consolidadas para analisis y reporting.',
    status: 'Implementado',
  },
  {
    title: 'API de Integracion en Django',
    stack: 'Django, DRF, PostgreSQL',
    description:
      'Diseno de endpoints para integrar datos entre sistemas internos y servicios externos con validaciones robustas.',
    status: 'En produccion',
  },
  {
    title: 'Dashboard de Indicadores Operativos',
    stack: 'Power BI, SQL, Python',
    description:
      'Diseno de indicadores y paneles ejecutivos para seguimiento semanal de eficiencia, tiempos y calidad operativa.',
    status: 'Activo',
  },
];
---

<Layout>
  <section class="relative isolate overflow-hidden pt-28 pb-16 px-4">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute -top-12 -left-16 h-72 w-72 rounded-full bg-emerald-300/20 blur-3xl dark:bg-emerald-500/15"
      >
      </div>
      <div
        class="absolute -bottom-16 -right-12 h-80 w-80 rounded-full bg-cyan-300/20 blur-3xl dark:bg-blue-500/15"
      >
      </div>
    </div>

    <div class="mx-auto max-w-5xl space-y-8">
      <header class="glass-panel rounded-2xl p-6">
        <p
          class="text-xs font-semibold uppercase tracking-[0.22em] text-black dark:text-slate-400"
        >
          Portafolio
        </p>
        <h1
          class="mt-2 text-3xl md:text-4xl font-bold leading-tight text-black dark:text-white"
        >
          Proyectos destacados
        </h1>
        <p class="mt-3 max-w-3xl text-black dark:text-slate-200">
          Seleccion de proyectos enfocados en integracion de datos, desarrollo backend y
          visualizacion para toma de decisiones.
        </p>
      </header>

      <section class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          projects.map((project) => (
            <article class="glass-panel-strong rounded-xl p-5">
              <p class="text-xs font-semibold uppercase tracking-wider text-emerald-800 dark:text-emerald-300">
                {project.status}
              </p>
              <h2 class="mt-1 text-lg font-semibold text-black dark:text-white">
                {project.title}
              </h2>
              <p class="mt-2 text-sm text-black dark:text-slate-200">{project.description}</p>
              <p class="mt-3 inline-flex rounded-md bg-sky-100 border border-sky-300 px-2 py-1 text-xs font-medium text-black dark:bg-slate-800 dark:text-slate-200 dark:border-transparent">
                {project.stack}
              </p>
            </article>
          ))
        }
      </section>
    </div>
  </section>
</Layout>
