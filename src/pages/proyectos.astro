---
import Layout from '../Layout.astro';
import '../styles/global.css';

const projects = [
  {
    title: 'P.U.L.S.O — Monitoreo de Sensores',
    stack: 'Django, DRF, PostgreSQL, WebSockets',
    description:
      'Backend de la Plataforma de Uso Libre de Sensores Operativos. Desarrollo de API REST en Django para ingesta, procesamiento y consulta de datos de sensores en tiempo real. Apoyo en ideas de UX para el frontend.',
    status: 'En produccion',
    url: 'http://tenten.innovex.cl:3001/',
    imageLight: '/dashboard_pulso_claro.png',
    imageDark: '/dashboard_pulso_oscuro.png',
  },
  {
    title: 'Pasaporte del Cafe',
    stack: 'Next.js, Django, DRF, Tailwind, Leaflet, PostgreSQL',
    description:
      'Plataforma colaborativa para evaluar la calidad de cafes de especialidad. Registro de granos, variedades, metodos de preparacion y valoraciones de la comunidad. Proyecto propio orientado a construir una red de entusiastas del cafe.',
    status: 'En desarrollo',
    imageLight: '/pasaporte_del_cafe.png',
    imageDark: '/pasaporte_del_cafe.png',
  },
  {
    title: 'Pipeline de Datos para Operaciones',
    stack: 'Python, SQL, PostgreSQL',
    description:
      'Automatizacion de flujo de datos desde fuentes operativas hasta tablas consolidadas para analisis y reporting.',
    status: 'Implementado',
  },
  {
    title: 'API de Integracion en Django',
    stack: 'Django, DRF, PostgreSQL',
    description:
      'Diseno de endpoints para integrar datos entre sistemas internos y servicios externos con validaciones robustas.',
    status: 'En produccion',
  },
  {
    title: 'Dashboard de Indicadores Operativos',
    stack: 'Power BI, SQL, Python',
    description:
      'Diseno de indicadores y paneles ejecutivos para seguimiento semanal de eficiencia, tiempos y calidad operativa.',
    status: 'Activo',
  },
];
---

<Layout>
  <section class="relative isolate overflow-hidden pt-28 pb-16 px-4">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute -top-12 -left-16 h-72 w-72 rounded-full bg-emerald-300/20 blur-3xl dark:bg-emerald-500/15"
      >
      </div>
      <div
        class="absolute -bottom-16 -right-12 h-80 w-80 rounded-full bg-cyan-300/20 blur-3xl dark:bg-blue-500/15"
      >
      </div>
    </div>

    <div class="mx-auto max-w-5xl space-y-8">
      <header class="glass-panel rounded-2xl p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-black dark:text-slate-400">
          Portafolio
        </p>
        <h1 class="mt-2 text-3xl md:text-4xl font-bold leading-tight text-black dark:text-white">
          Proyectos destacados
        </h1>
        <p class="mt-3 max-w-3xl text-black dark:text-slate-200">
          Seleccion de proyectos enfocados en integracion de datos, desarrollo backend y
          visualizacion para toma de decisiones.
        </p>
      </header>

      <section class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          projects.map((project) => (
            <article
              class={`glass-panel-strong rounded-xl flex flex-col overflow-hidden ${project.imageLight ? 'p-0' : 'p-5'}`}
            >
              {project.imageLight && (
                <div class="relative w-full h-44 overflow-hidden">
                  <img
                    src={project.imageLight}
                    alt={project.title}
                    class="w-full h-full object-cover object-top dark:hidden"
                    loading="lazy"
                  />
                  <img
                    src={project.imageDark}
                    alt={project.title}
                    class="w-full h-full object-cover object-top hidden dark:block"
                    loading="lazy"
                  />
                </div>
              )}
              <div class={`flex flex-col flex-1 ${project.imageLight ? 'p-5' : ''}`}>
                <p class="text-xs font-semibold uppercase tracking-wider text-emerald-800 dark:text-emerald-300">
                  {project.status}
                </p>
                <h2 class="mt-1 text-lg font-semibold text-black dark:text-white">
                  {project.title}
                </h2>
                <p class="mt-2 text-sm text-black dark:text-slate-200">{project.description}</p>
                <div class="mt-auto pt-3 flex items-center justify-between gap-2">
                  <span class="inline-flex rounded-md bg-sky-100 border border-sky-300 px-2 py-1 text-xs font-medium text-black dark:bg-slate-800 dark:text-slate-200 dark:border-transparent">
                    {project.stack}
                  </span>
                  {project.url && (
                    <a
                      href={project.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 rounded-md bg-blue-600 px-2.5 py-1 text-xs font-medium text-white hover:bg-blue-700 transition-colors dark:bg-blue-500 dark:hover:bg-blue-600"
                    >
                      Ver
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-3 w-3"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M3 4a1 1 0 011-1h7a1 1 0 010 2H5v10h10v-6a1 1 0 112 0v7a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm11-1a1 1 0 000 2h1.586l-4.293 4.293a1 1 0 001.414 1.414L17 6.414V8a1 1 0 102 0V4a1 1 0 00-1-1h-4z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))
        }
      </section>
    </div>
  </section>
</Layout>
