---
import Layout from '../Layout.astro';
import '../styles/global.css';
---

<Layout>
  <section class="relative isolate overflow-hidden pt-28 pb-16 px-4">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-12 -left-16 h-72 w-72 rounded-full bg-amber-300/20 blur-3xl dark:bg-amber-500/15"></div>
      <div class="absolute -bottom-16 -right-12 h-80 w-80 rounded-full bg-fuchsia-300/20 blur-3xl dark:bg-fuchsia-500/15"></div>
    </div>

    <div class="mx-auto max-w-4xl space-y-8">
      <header class="rounded-2xl border border-slate-200/70 bg-white/70 p-6 shadow-sm backdrop-blur-md dark:border-slate-700/70 dark:bg-slate-900/55">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-600 dark:text-slate-400">
          Contacto
        </p>
        <h1 class="mt-2 text-3xl md:text-4xl font-bold leading-tight text-slate-900 dark:text-white">
          Conversemos sobre tu proyecto
        </h1>
        <p class="mt-3 max-w-3xl text-slate-700 dark:text-slate-300">
          Si tienes una idea, un desafio de datos o necesitas apoyo en desarrollo, puedo ayudarte a construir una solucion clara y escalable.
        </p>
      </header>

      <section class="grid gap-4 md:grid-cols-2">
        <article class="rounded-xl border border-slate-200/80 bg-white/80 p-5 shadow-sm backdrop-blur-md dark:border-slate-700/80 dark:bg-slate-900/65">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Canales</h2>
          <ul class="mt-3 space-y-2 text-slate-700 dark:text-slate-300">
            <li>Email: <a href="mailto:marcelo@example.com" class="text-blue-700 dark:text-blue-400">marcelo@example.com</a></li>
            <li>LinkedIn: <a href="#" class="text-blue-700 dark:text-blue-400">Perfil profesional</a></li>
            <li>GitHub: <a href="#" class="text-blue-700 dark:text-blue-400">Repositorio</a></li>
          </ul>
        </article>

        <article class="rounded-xl border border-slate-200/80 bg-white/80 p-5 shadow-sm backdrop-blur-md dark:border-slate-700/80 dark:bg-slate-900/65">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Disponibilidad</h2>
          <p class="mt-3 text-slate-700 dark:text-slate-300">
            Actualmente disponible para colaborar en proyectos freelance, integraciones backend y soluciones con datos.
          </p>
          <p class="mt-4 inline-flex rounded-md border border-emerald-300/70 bg-emerald-50 px-3 py-1 text-sm font-medium text-emerald-800 dark:border-emerald-600/50 dark:bg-emerald-900/25 dark:text-emerald-200">
            Respuesta estimada: 24 - 48 horas
          </p>
        </article>
      </section>
    </div>
  </section>
</Layout>
