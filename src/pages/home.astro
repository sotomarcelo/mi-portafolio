---
import Layout from '../Layout.astro';
import Card from '../components/Card.astro';
import CarruselTechs from '../components/CarruselTechs.astro';
import '../styles/global.css';
---

<Layout>
  <section
    class="inicio-readable flex flex-col items-center justify-center min-h-screen bg-base-200 py-4 pt-24"
    style={`min-height:unset;height:100vh;`}
  >
    <!-- Título eliminado por solicitud del usuario -->
    <div
      class="grid grid-cols-1 grid-rows-10 gap-2 w-full max-w-7xl px-4
      sm:grid-cols-12 sm:grid-rows-10"
      style="height:75vh;min-height:400px;max-height:700px;"
    >
      <Card
        title="Experiencia"
        colorClass="border-pink-400 col-span-1 row-span-1 sm:col-start-7 sm:col-span-6 sm:row-start-1 sm:row-span-4"
      >
        <div class="relative">
          <!-- Default slot: contenido del card -->
          <div class="experience-scroll">
            <ol class="relative border-s border-base-300 ml-2 mt-2">
              <li class="mb-4 ms-4">
                <div
                  class="absolute w-3 h-3 bg-blue-400 rounded-full mt-1.5 -start-1.5 border border-base-100"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-base-content/60"
                  >nov. 2024 - Actualidad</time
                >
                <p class="text-sm font-semibold text-base-content">
                  Ingeniero de Desarrollo - Innovex SpA
                </p>
              </li>
              <li class="mb-4 ms-4">
                <div
                  class="absolute w-3 h-3 bg-pink-400 rounded-full mt-1.5 -start-1.5 border border-base-100"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-base-content/60"
                  >sep. 2023 - jun. 2024</time
                >
                <p class="text-sm font-semibold text-base-content">
                  Analista de Datos - EQUANS
                </p>
              </li>
              <li class="mb-4 ms-4">
                <div
                  class="absolute w-3 h-3 bg-green-400 rounded-full mt-1.5 -start-1.5 border border-base-100"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-base-content/60"
                  >ene. 2021 - sep. 2023</time
                >
                <p class="text-sm font-semibold text-base-content">
                  Colaborador y Tesista - SOPHIA
                </p>
              </li>
              <li class="ms-4">
                <div
                  class="absolute w-3 h-3 bg-yellow-400 rounded-full mt-1.5 -start-1.5 border border-base-100"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-base-content/60"
                  >ene. 2019 - feb. 2019</time
                >
                <p class="text-sm font-semibold text-base-content">
                  Encargado de Trazabilidad - Framberry
                </p>
              </li>
            </ol>
          </div>

          <!-- Botón fijo en la esquina inferior derecha del card (no desenfocado) -->
          <div slot="overlay">
            <a
              href="/experiencia"
              class="btn btn-primary btn-sm absolute bottom-3 right-3 z-20"
              aria-label="Ver más experiencia"
            >
              Ver detalle completo
            </a>
          </div>
        </div>
      </Card>

      <!-- C: Proyectos -->
      <Card
        id="proyectos"
        title="Proyectos"
        colorClass="border-green-400 col-span-1 row-span-1 sm:col-start-1 sm:col-span-4 sm:row-start-5 sm:row-span-4"
        content="Algunos de mis proyectos destacados en desarrollo web, aplicaciones y más."
        showButton={true}
        buttonText="Ver proyectos"
        buttonHref="/proyectos"
      />
      <!-- D: Contacto -->
      <Card
        id="contactame"
        title="Contáctame"
        colorClass="border-yellow-400 col-span-1 row-span-1 sm:col-start-5 sm:col-span-4 sm:row-start-5 sm:row-span-4"
        content="¿Tienes un proyecto o quieres colaborar? Escríbeme y conversemos sobre cómo puedo ayudar."
        showButton={true}
        buttonText="Ir a contacto"
        buttonHref="/inicio#contactame"
      />
      <!-- E: 2x2 -->
      <Card
        title="E"
        colorClass="border-purple-400 col-span-1 row-span-1 sm:col-start-9 sm:col-span-4 sm:row-start-5 sm:row-span-4"
        content="Columna E"
      />
      <!-- F: 6x1 -->
      <Card
        title="Tecnologías"
        colorClass="border-base-300 col-span-1 row-span-1 sm:col-start-1 sm:col-span-12 sm:row-start-9 sm:row-span-2"
      >
        <div class="w-full sm:pb-8">
          <CarruselTechs />
        </div>
      </Card>
    </div>
  </section>
</Layout>
