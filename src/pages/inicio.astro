---
import Layout from '../Layout.astro';
import Card from '../components/Card.astro';
import CarruselTechs from '../components/CarruselTechs.astro';
import '../styles/global.css';

const projectPreviews = [
  {
    title: 'P.U.L.S.O — Monitoreo',
    summary: 'Backend Django para ingesta y consulta de datos de sensores en tiempo real.',
    href: '/proyectos',
    imageLight: '/dashboard_pulso_claro.png',
    imageDark: '/dashboard_pulso_oscuro.png',
  },
  {
    title: 'Pasaporte del Cafe',
    summary: 'Comunidad colaborativa para evaluar cafes de especialidad, granos y preparaciones.',
    href: '/proyectos',
    image: '/pasaporte_del_cafe.png',
  },
  {
    title: 'API y Pipelines de Datos',
    summary: 'Backend y procesamiento de datos con validacion y transformacion.',
    href: '/proyectos',
    image: '/projects/proyecto-api.svg',
  },
  {
    title: 'Dashboard Operativo',
    summary: 'Indicadores y visualizacion para seguimiento de eficiencia.',
    href: '/proyectos',
    image: '/projects/proyecto-dashboard.svg',
  },
  {
    title: 'ETL y NLP',
    summary: 'Automatizacion de extraccion, limpieza y analisis de texto.',
    href: '/proyectos',
    image: '/projects/proyecto-etl.svg',
  },
];
---

<Layout>
  <section
    class="inicio-readable flex flex-col items-center justify-center min-h-screen bg-gray-50 dark:bg-gray-900 py-4 pt-24"
    style={`min-height:unset;height:100vh;`}
  >
    <!-- Título eliminado por solicitud del usuario -->
    <div
      class="grid grid-cols-1 grid-rows-10 gap-2 w-full max-w-7xl px-4
      sm:grid-cols-12 sm:grid-rows-10"
      style="height:75vh;min-height:400px;max-height:700px;"
    >
      <!-- A: Sobre mí (formato personalizado) -->
      <Card
        title="Sobre mí"
        colorClass="border-blue-400 dark:border-blue-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-1 sm:col-span-6 sm:row-start-1 sm:row-span-4"
      >
        <div class="flex flex-col gap-3 h-full">
          <h3 class="text-2xl font-extrabold tracking-tight text-black dark:text-white">
            Marcelo Soto
          </h3>
          <p class="text-sm leading-relaxed text-black dark:text-gray-200">
            Soy Ingeniero de Desarrollo Fullstack con foco en productos utiles, datos y
            automatizacion.
          </p>

          <div class="mt-2 flex items-center gap-3 text-black dark:text-white">
            <span
              class="status-chip inline-flex items-center gap-2 px-3 py-1 rounded-lg border border-emerald-400 bg-emerald-100 text-sm font-bold text-black shadow-sm dark:border-emerald-500/50 dark:bg-emerald-500/15 dark:text-emerald-200"
            >
              <span class="w-2 h-2 rounded-full bg-emerald-600 inline-block animate-pulse"></span>
              Disponible para nuevos proyectos
            </span>
          </div>

          <div class="flex flex-wrap gap-2">
            <span
              class="inline-flex rounded-md bg-sky-100 border border-sky-300 px-2.5 py-1 text-xs font-bold text-black dark:bg-slate-800 dark:border-transparent dark:text-slate-200"
            >
              Backend + Datos
            </span>
            <span
              class="inline-flex rounded-md bg-amber-100 border border-amber-300 px-2.5 py-1 text-xs font-bold text-black dark:bg-blue-900/30 dark:border-transparent dark:text-blue-200"
            >
              Valdivia, Chile
            </span>
            <span
              class="inline-flex rounded-md bg-violet-100 border border-violet-300 px-2.5 py-1 text-xs font-bold text-black dark:bg-violet-900/30 dark:border-transparent dark:text-violet-200"
            >
              Python | Django | SQL
            </span>
          </div>

          <div class="mt-auto pt-2 flex items-center gap-4">
            <!-- Social links -->
            <a
              href="https://github.com/sotomarcelo"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-black shadow-sm transition-colors hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700"
              aria-label="GitHub"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M12 .5a12 12 0 00-3.79 23.4c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.58-4.04-1.58-.55-1.4-1.34-1.77-1.34-1.77-1.09-.75.08-.74.08-.74 1.2.08 1.83 1.23 1.83 1.23 1.07 1.82 2.8 1.29 3.48.99.11-.77.42-1.29.76-1.59-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.53-1.52.12-3.17 0 0 1-.32 3.3 1.23a11.5 11.5 0 016 0C17.3 4.2 18.3 4.5 18.3 4.5c.65 1.65.24 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.6-2.8 5.63-5.47 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.82.58A12 12 0 0012 .5"
                ></path></svg
              >
              GitHub
            </a>
            <a
              href="https://www.linkedin.com/in/marcelo-soto-barria-30765720b/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-black shadow-sm transition-colors hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700"
              aria-label="LinkedIn"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M4.98 3.5C4.98 4.88 3.86 6 2.48 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM0 8h5v16H0zM8 8h4.8v2.4h.1C13.7 8.8 15.7 8 18 8 22 8 24 10.2 24 14.7V24h-5v-8.3c0-2-1.2-3-2.6-3-1.5 0-2.2 1-2.2 3V24H8V8z"
                ></path></svg
              >
              LinkedIn
            </a>
          </div>
        </div>
      </Card>
      <!-- B: Experiencia (Roadmap) -->
      <Card
        title="Mi experiencia"
        colorClass="border-pink-400 dark:border-pink-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-7 sm:col-span-6 sm:row-start-1 sm:row-span-4"
      >
        <div class="relative">
          <div class="experience-scroll">
            <ol
              class="relative border-s border-gray-200 dark:border-gray-700 ml-2 mt-2 transition-all duration-200"
            >
              <li class="mb-4 ms-4">
                <div
                  class="absolute w-3 h-3 bg-blue-200 rounded-full mt-1.5 -start-1.5 border border-white dark:bg-blue-600 dark:border-gray-900"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-black dark:text-gray-400"
                  >nov. 2024 - Actualidad</time
                >
                <p class="text-sm font-semibold text-black dark:text-white">
                  Ingeniero de Desarrollo - Innovex SpA
                </p>
              </li>
              <li class="mb-4 ms-4">
                <div
                  class="absolute w-3 h-3 bg-pink-200 rounded-full mt-1.5 -start-1.5 border border-white dark:bg-pink-600 dark:border-gray-900"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-black dark:text-gray-400"
                  >sep. 2023 - jun. 2024</time
                >
                <p class="text-sm font-semibold text-black dark:text-white">
                  Analista de Datos - EQUANS
                </p>
              </li>
              <li class="mb-4 ms-4">
                <div
                  class="absolute w-3 h-3 bg-green-200 rounded-full mt-1.5 -start-1.5 border border-white dark:bg-green-600 dark:border-gray-900"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-black dark:text-gray-400"
                  >ene. 2021 - sep. 2023</time
                >
                <p class="text-sm font-semibold text-black dark:text-white">
                  Colaborador y Tesista - SOPHIA
                </p>
              </li>
              <li class="ms-4">
                <div
                  class="absolute w-3 h-3 bg-yellow-200 rounded-full mt-1.5 -start-1.5 border border-white dark:bg-yellow-600 dark:border-gray-900"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-black dark:text-gray-400"
                  >ene. 2019 - feb. 2019</time
                >
                <p class="text-sm font-semibold text-black dark:text-white">
                  Encargado de Trazabilidad - Framberry
                </p>
              </li>
            </ol>
          </div>
          <!-- Botón fijo en la esquina inferior derecha del card (no desenfocado) -->
          <div slot="overlay">
            <a
              href="/experiencia"
              class="absolute bottom-3 right-3 z-20 inline-flex items-center px-3 py-1.5 bg-blue-600 text-white rounded-md shadow hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-300 dark:bg-blue-500 dark:hover:bg-blue-600"
              aria-label="Ver más experiencia"
            >
              Ver detalle completo
            </a>
          </div>
        </div>
      </Card>
      <!-- C: Proyectos -->
      <Card
        id="proyectos"
        title="Proyectos"
        colorClass="border-green-400 dark:border-green-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-1 sm:col-span-4 sm:row-start-5 sm:row-span-4"
      >
        <div
          class="project-preview relative mt-2 h-44 sm:h-48 overflow-hidden rounded-xl border border-slate-200/80 dark:border-slate-700/80"
          data-project-preview
        >
          {
            projectPreviews.map((project, index) => (
              <article
                class={`project-slide group relative h-full ${index === 0 ? '' : 'hidden'}`}
                data-project-slide
              >
                {project.imageLight ? (
                  <>
                    <img
                      src={project.imageLight}
                      alt={project.title}
                      class="h-full w-full object-cover object-top dark:hidden"
                      loading="lazy"
                    />
                    <img
                      src={project.imageDark}
                      alt={project.title}
                      class="h-full w-full object-cover object-top hidden dark:block"
                      loading="lazy"
                    />
                  </>
                ) : (
                  <img
                    src={project.image}
                    alt={project.title}
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                )}
                <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-slate-900/80 to-transparent px-3 py-2">
                  <p class="text-sm font-medium text-white">{project.title}</p>
                </div>

                <div class="absolute inset-0 bg-slate-900/65 opacity-0 transition-opacity duration-200 group-hover:opacity-100">
                  <div class="flex h-full flex-col justify-end gap-2 p-3">
                    <p class="text-sm font-semibold text-white">{project.title}</p>
                    <p class="text-xs text-slate-200">{project.summary}</p>
                    <a
                      href={project.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex w-fit items-center rounded-md bg-emerald-500 px-2.5 py-1 text-xs font-medium text-white hover:bg-emerald-600"
                    >
                      Ir al proyecto
                    </a>
                  </div>
                </div>
              </article>
            ))
          }

          <button
            type="button"
            data-project-prev
            class="absolute left-2 top-2 inline-flex h-7 w-7 items-center justify-center rounded-full bg-black/35 text-white hover:bg-black/55"
            aria-label="Proyecto anterior"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M12.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 111.414 1.414L9.414 10l3.293 3.293a1 1 0 010 1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </button>

          <button
            type="button"
            data-project-next
            class="absolute right-2 top-2 inline-flex h-7 w-7 items-center justify-center rounded-full bg-black/35 text-white hover:bg-black/55"
            aria-label="Siguiente proyecto"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                clip-rule="evenodd"></path>
            </svg>
          </button>

          <div
            class="absolute inset-x-0 bottom-1.5 flex items-center justify-center gap-1.5"
            aria-hidden="true"
          >
            {
              projectPreviews.map((_, index) => (
                <button
                  type="button"
                  data-project-dot
                  data-project-index={index}
                  class={`h-1.5 w-1.5 rounded-full ${index === 0 ? 'bg-emerald-400' : 'bg-white/55'}`}
                  aria-label={`Ir al proyecto ${index + 1}`}
                />
              ))
            }
          </div>
        </div>
      </Card>
      <!-- D: Contacto -->
      <Card
        id="contactame"
        title="Contáctame"
        colorClass="border-yellow-400 dark:border-yellow-500 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-5 sm:col-span-4 sm:row-start-5 sm:row-span-4"
      >
        <div class="flex h-full flex-col gap-3">
          <p class="text-sm text-black dark:text-gray-300">
            Si tienes una idea o necesitas apoyo tecnico, escribeme por el canal que prefieras.
          </p>

          <div
            class="rounded-lg border border-yellow-300 bg-yellow-50 p-3 dark:border-slate-700 dark:bg-slate-800/70"
          >
            <div class="flex items-center gap-2.5">
              <span
                class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-white border border-yellow-300 text-black shadow-sm dark:border-transparent dark:bg-blue-900/40 dark:text-blue-300"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M2.94 5.5A2 2 0 014.83 4h10.34a2 2 0 011.89 1.5L10 9.88 2.94 5.5z"
                  ></path>
                  <path
                    d="M18 8.12l-7.48 4.64a1 1 0 01-1.04 0L2 8.12V14a2 2 0 002 2h12a2 2 0 002-2V8.12z"
                  ></path>
                </svg>
              </span>
              <div class="min-w-0 flex-1">
                <p
                  class="text-xs font-semibold uppercase tracking-wide text-black dark:text-slate-400"
                >
                  Correo
                </p>
                <p class="truncate text-sm font-medium text-black dark:text-slate-100">
                  contacto.sotomarcelo@gmail.com
                </p>
              </div>
              <a
                href="mailto:contacto.sotomarcelo@gmail.com"
                class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-black shadow-sm transition-colors hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-300 dark:hover:bg-slate-600"
                aria-label="Abrir correo"
                title="Abrir correo"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M3 4a1 1 0 011-1h7a1 1 0 010 2H5v10h10v-6a1 1 0 112 0v7a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm11-1a1 1 0 000 2h1.586l-4.293 4.293a1 1 0 001.414 1.414L17 6.414V8a1 1 0 102 0V4a1 1 0 00-1-1h-4z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
            </div>
          </div>

          <div
            class="rounded-lg border border-yellow-300 bg-yellow-50 p-3 dark:border-slate-700 dark:bg-slate-800/70"
          >
            <div class="flex items-center gap-2.5">
              <span
                class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-white border border-yellow-300 text-black shadow-sm dark:border-transparent dark:bg-emerald-900/40 dark:text-emerald-300"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.149-.198.298-.767.968-.94 1.166-.173.198-.347.223-.644.075-.297-.149-1.255-.463-2.39-1.475-.883-.787-1.48-1.759-1.653-2.056-.173-.297-.018-.458.13-.606.135-.135.297-.347.446-.52.15-.174.198-.298.298-.497.1-.198.05-.372-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.372-.01-.57-.01-.198 0-.52.075-.792.372-.272.298-1.04 1.016-1.04 2.48 0 1.463 1.065 2.877 1.213 3.075.149.198 2.095 3.2 5.076 4.487.711.307 1.266.49 1.698.627.713.227 1.362.195 1.875.118.572-.086 1.758-.719 2.007-1.413.248-.695.248-1.29.173-1.413-.075-.124-.272-.198-.57-.347z"
                  ></path>
                  <path
                    d="M20.52 3.478A11.947 11.947 0 0012.042 0C5.462 0 .104 5.357.104 11.938c0 2.104.55 4.159 1.595 5.969L0 24l6.26-1.643a11.95 11.95 0 005.782 1.474h.005c6.58 0 11.938-5.357 11.938-11.938a11.89 11.89 0 00-3.465-8.415zM12.047 21.82h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.713.974.99-3.62-.235-.372a9.83 9.83 0 01-1.505-5.27c.002-5.42 4.413-9.83 9.835-9.83 2.626.001 5.096 1.024 6.952 2.88a9.77 9.77 0 012.883 6.956c-.002 5.422-4.414 9.832-9.83 9.832z"
                  ></path>
                </svg>
              </span>
              <div class="min-w-0 flex-1">
                <p
                  class="text-xs font-semibold uppercase tracking-wide text-black dark:text-slate-400"
                >
                  WhatsApp
                </p>
                <p class="truncate text-sm font-medium text-black dark:text-slate-100">
                  +56 9 4289 6509
                </p>
              </div>
              <a
                href="https://wa.me/56942896509"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-black shadow-sm transition-colors hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-300 dark:hover:bg-slate-600"
                aria-label="Abrir WhatsApp"
                title="Abrir WhatsApp"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M3 4a1 1 0 011-1h7a1 1 0 010 2H5v10h10v-6a1 1 0 112 0v7a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm11-1a1 1 0 000 2h1.586l-4.293 4.293a1 1 0 001.414 1.414L17 6.414V8a1 1 0 102 0V4a1 1 0 00-1-1h-4z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </Card>
      <!-- E: 2x2 -->
      <Card
        title="Enfoque"
        colorClass="border-purple-400 dark:border-purple-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-9 sm:col-span-4 sm:row-start-5 sm:row-span-4"
      >
        <p class="text-sm text-black dark:text-gray-300">
          Trabajo con una mezcla de ingenieria de software y analitica para entregar soluciones
          utiles, trazables y faciles de mantener.
        </p>
        <div class="mt-3 grid grid-cols-1 gap-2 text-sm text-black dark:text-gray-300">
          <span
            class="rounded-md bg-purple-100 border border-purple-300 px-2 py-1 text-black font-medium dark:border-transparent dark:bg-slate-800/70 dark:text-gray-300"
            >Codigo limpio y documentado</span
          >
          <span
            class="rounded-md bg-purple-100 border border-purple-300 px-2 py-1 text-black font-medium dark:border-transparent dark:bg-slate-800/70 dark:text-gray-300"
            >Automatizacion de procesos</span
          >
          <span
            class="rounded-md bg-purple-100 border border-purple-300 px-2 py-1 text-black font-medium dark:border-transparent dark:bg-slate-800/70 dark:text-gray-300"
            >Enfoque en impacto real</span
          >
        </div>
      </Card>
      <!-- F: 6x1 -->
      <Card
        title="Mi Stack"
        colorClass="border-gray-400 dark:border-gray-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-1 sm:col-span-12 sm:row-start-9 sm:row-span-2"
      >
        <button
          type="button"
          slot="title-action"
          data-open-tech-modal
          class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-black shadow-sm transition-colors hover:bg-slate-100 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700"
          aria-label="Ver stack completo"
          title="Ver stack completo"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
            ></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </button>

        <div class="w-full sm:pb-8">
          <CarruselTechs />
        </div>
      </Card>
    </div>

    <div
      id="tech-modal"
      class="hidden fixed inset-0 z-50 items-center justify-center p-4"
      role="dialog"
