---
import Layout from '../Layout.astro';
import Card from '../components/Card.astro';
import CarruselTechs from '../components/CarruselTechs.astro';
import '../styles/global.css';
---

<Layout>
  <section
    class="inicio-readable flex flex-col items-center justify-center min-h-screen bg-gray-50 dark:bg-gray-900 py-4 pt-24"
    style={`min-height:unset;height:100vh;background-color: var(--page-bg); color: var(--page-color);`}
  >
    <!-- Título eliminado por solicitud del usuario -->
    <div
      class="grid grid-cols-1 grid-rows-10 gap-2 w-full max-w-7xl px-4
      sm:grid-cols-12 sm:grid-rows-10"
      style="height:75vh;min-height:400px;max-height:700px;"
    >
      <!-- A: Sobre mí (formato personalizado) -->
      <Card
        title="Sobre mí"
        colorClass="border-blue-400 dark:border-blue-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-1 sm:col-span-6 sm:row-start-1 sm:row-span-4"
      >
        <div class="flex flex-col gap-3 h-full">
          <h3 class="text-2xl font-extrabold tracking-tight text-gray-900 dark:text-white">Marcelo Soto</h3>
          <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
            Soy Ingeniero de Desarrollo Fullstack con foco en productos utiles, datos y automatizacion.
          </p>

          <div class="mt-2 flex items-center gap-3 text-gray-900 dark:text-white">
            <span
              class="status-chip inline-flex items-center gap-2 px-3 py-1 rounded-lg border border-emerald-300/80 bg-emerald-50 text-sm font-medium text-emerald-800 shadow-sm dark:border-emerald-500/50 dark:bg-emerald-500/15 dark:text-emerald-200"
            >
              <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block animate-pulse"></span>
              Disponible para nuevos proyectos
            </span>
          </div>

          <div class="mt-auto pt-2 flex items-center gap-4">
            <!-- Social icons (placeholder links) -->
            <a
              href="#"
              class="text-gray-500 hover:text-blue-700 transition-colors dark:text-gray-300 dark:hover:text-blue-400"
              aria-label="Twitter"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M8 19c7.333 0 11.333-6.083 11.333-11.333v-.516A8.097 8.097 0 0021 5.5a7.75 7.75 0 01-2.167.6A3.778 3.778 0 0020.333 4a7.583 7.583 0 01-2.417.917A3.79 3.79 0 0013.5 3c-2.083 0-3.75 1.667-3.75 3.75 0 .292.042.583.125.833A10.75 10.75 0 013 4.917a3.75 3.75 0 001.167 5 3.708 3.708 0 01-1.708-.458v.042c0 1.833 1.25 3.333 2.917 3.667a3.778 3.778 0 01-1.7.083c.5 1.667 2 2.875 3.75 2.917A7.583 7.583 0 013 17.917C4.667 18.833 6.5 19 8 19"
                ></path></svg
              >
            </a>
            <a
              href="#"
              class="text-gray-500 hover:text-pink-600 transition-colors dark:text-gray-300 dark:hover:text-pink-400"
              aria-label="Instagram"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zm5 6a5 5 0 100 10 5 5 0 000-10z"
                ></path></svg
              >
            </a>
            <a
              href="#"
              class="text-gray-500 hover:text-gray-900 transition-colors dark:text-gray-300 dark:hover:text-white"
              aria-label="GitHub"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M12 .5a12 12 0 00-3.79 23.4c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.58-4.04-1.58-.55-1.4-1.34-1.77-1.34-1.77-1.09-.75.08-.74.08-.74 1.2.08 1.83 1.23 1.83 1.23 1.07 1.82 2.8 1.29 3.48.99.11-.77.42-1.29.76-1.59-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.53-1.52.12-3.17 0 0 1-.32 3.3 1.23a11.5 11.5 0 016 0C17.3 4.2 18.3 4.5 18.3 4.5c.65 1.65.24 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.6-2.8 5.63-5.47 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.82.58A12 12 0 0012 .5"
                ></path></svg
              >
            </a>
            <a
              href="#"
              class="text-gray-500 hover:text-blue-700 transition-colors dark:text-gray-300 dark:hover:text-blue-400"
              aria-label="LinkedIn"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M4.98 3.5C4.98 4.88 3.86 6 2.48 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM0 8h5v16H0zM8 8h4.8v2.4h.1C13.7 8.8 15.7 8 18 8 22 8 24 10.2 24 14.7V24h-5v-8.3c0-2-1.2-3-2.6-3-1.5 0-2.2 1-2.2 3V24H8V8z"
                ></path></svg
              >
            </a>
          </div>
        </div>
      </Card>
      <!-- B: Experiencia (Roadmap) -->
      <Card
        title="Mi experiencia"
        colorClass="border-pink-400 dark:border-pink-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-7 sm:col-span-6 sm:row-start-1 sm:row-span-4"
      >
        <div class="relative">
          <div class="experience-scroll">
            <ol
              class="relative border-s border-gray-200 dark:border-gray-700 ml-2 mt-2 transition-all duration-200"
            >
              <li class="mb-4 ms-4">
                <div
                  class="absolute w-3 h-3 bg-blue-200 rounded-full mt-1.5 -start-1.5 border border-white dark:bg-blue-600 dark:border-gray-900"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-gray-600 dark:text-gray-400"
                  >nov. 2024 - Actualidad</time
                >
                <p class="text-sm font-semibold text-gray-900 dark:text-white">
                  Ingeniero de Desarrollo - Innovex SpA
                </p>
              </li>
              <li class="mb-4 ms-4">
                <div
                  class="absolute w-3 h-3 bg-pink-200 rounded-full mt-1.5 -start-1.5 border border-white dark:bg-pink-600 dark:border-gray-900"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-gray-600 dark:text-gray-400"
                  >sep. 2023 - jun. 2024</time
                >
                <p class="text-sm font-semibold text-gray-900 dark:text-white">
                  Analista de Datos - EQUANS
                </p>
              </li>
              <li class="mb-4 ms-4">
                <div
                  class="absolute w-3 h-3 bg-green-200 rounded-full mt-1.5 -start-1.5 border border-white dark:bg-green-600 dark:border-gray-900"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-gray-600 dark:text-gray-400"
                  >ene. 2021 - sep. 2023</time
                >
                <p class="text-sm font-semibold text-gray-900 dark:text-white">
                  Colaborador y Tesista - SOPHIA
                </p>
              </li>
              <li class="ms-4">
                <div
                  class="absolute w-3 h-3 bg-yellow-200 rounded-full mt-1.5 -start-1.5 border border-white dark:bg-yellow-600 dark:border-gray-900"
                >
                </div>
                <time class="mb-1 text-xs font-normal leading-none text-gray-600 dark:text-gray-400"
                  >ene. 2019 - feb. 2019</time
                >
                <p class="text-sm font-semibold text-gray-900 dark:text-white">
                  Encargado de Trazabilidad - Framberry
                </p>
              </li>
            </ol>
          </div>
          <!-- Botón fijo en la esquina inferior derecha del card (no desenfocado) -->
          <div slot="overlay">
            <a
              href="/experiencia"
              class="absolute bottom-3 right-3 z-20 inline-flex items-center px-3 py-1.5 bg-blue-600 text-white rounded-md shadow hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-300 dark:bg-blue-500 dark:hover:bg-blue-600"
              aria-label="Ver más experiencia"
            >
              Ver detalle completo
            </a>
          </div>
        </div>
      </Card>
      <!-- C: Proyectos -->
      <Card
        id="proyectos"
        title="Proyectos"
        colorClass="border-green-400 dark:border-green-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-1 sm:col-span-4 sm:row-start-5 sm:row-span-4"
        content="Algunos de mis proyectos destacados en desarrollo web, aplicaciones y más."
        showButton={true}
        buttonText="Ver proyectos"
        buttonHref="/proyectos"
      />
      <!-- D: Contacto -->
      <Card
        id="contactame"
        title="Contáctame"
        colorClass="border-yellow-400 dark:border-yellow-500 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-5 sm:col-span-4 sm:row-start-5 sm:row-span-4"
        content="¿Tienes un proyecto o quieres colaborar? Escríbeme y conversemos sobre cómo puedo ayudar."
        showButton={true}
        buttonText="Ir a contacto"
        buttonHref="/contactame"
      />
      <!-- E: 2x2 -->
      <Card
        title="E"
        colorClass="border-purple-400 dark:border-purple-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-9 sm:col-span-4 sm:row-start-5 sm:row-span-4"
        content="Columna E"
      />
      <!-- F: 6x1 -->
      <Card
        title="Mi Stack"
        colorClass="border-gray-400 dark:border-gray-600 bg-white dark:bg-gray-800 col-span-1 row-span-1 sm:col-start-1 sm:col-span-12 sm:row-start-9 sm:row-span-2"
      >
        <button
          type="button"
          slot="title-action"
          data-open-tech-modal
          class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-700 shadow-sm transition-colors hover:bg-slate-100 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700"
          aria-label="Ver stack completo"
          title="Ver stack completo"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
            ></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </button>

        <div class="w-full sm:pb-8">
          <CarruselTechs />
        </div>
      </Card>
    </div>

    <div
      id="tech-modal"
      class="hidden fixed inset-0 z-50 items-center justify-center p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="tech-modal-title"
    >
      <div data-tech-modal-backdrop class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>

      <div
        class="relative z-10 w-full max-w-3xl rounded-2xl border border-slate-200/70 bg-white/95 p-5 shadow-2xl dark:border-slate-700/70 dark:bg-slate-900/95"
      >
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 id="tech-modal-title" class="text-xl font-bold text-slate-900 dark:text-white">
              Tecnologias por categoria
            </h2>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">
              Resumen del stack principal que utilizo en proyectos de desarrollo y datos.
            </p>
          </div>
          <button
            type="button"
            data-close-tech-modal
            class="rounded-md border border-slate-300 px-2 py-1 text-sm text-slate-600 hover:bg-slate-100 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-800"
            aria-label="Cerrar modal"
          >
            Cerrar
          </button>
        </div>

        <div class="mt-4 grid gap-4 md:grid-cols-2">
          <article class="rounded-lg border border-cyan-200/80 bg-cyan-50/70 p-4 dark:border-cyan-800/70 dark:bg-cyan-950/20">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-cyan-800 dark:text-cyan-200">
              Frontend
            </h3>
            <div class="mt-2 flex flex-wrap gap-2">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/react.svg" alt="React" class="h-3.5 w-3.5" loading="lazy" />React</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/nextjs.svg" alt="Next.js" class="h-3.5 w-3.5" loading="lazy" />Next.js</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/astro.svg" alt="Astro" class="h-3.5 w-3.5" loading="lazy" />Astro</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/html5.svg" alt="HTML5" class="h-3.5 w-3.5" loading="lazy" />HTML5</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/css3.svg" alt="CSS3" class="h-3.5 w-3.5" loading="lazy" />CSS3</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/tailwindcss.svg" alt="Tailwind CSS" class="h-3.5 w-3.5" loading="lazy" />Tailwind CSS</span>
            </div>
          </article>

          <article class="rounded-lg border border-emerald-200/80 bg-emerald-50/70 p-4 dark:border-emerald-800/70 dark:bg-emerald-950/20">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-emerald-800 dark:text-emerald-200">
              Backend
            </h3>
            <div class="mt-2 flex flex-wrap gap-2">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/python.svg" alt="Python" class="h-3.5 w-3.5" loading="lazy" />Python</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/django.svg" alt="Django" class="h-3.5 w-3.5" loading="lazy" />Django</span>
            </div>
          </article>

          <article class="rounded-lg border border-indigo-200/80 bg-indigo-50/70 p-4 dark:border-indigo-800/70 dark:bg-indigo-950/20 md:col-span-2">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-indigo-800 dark:text-indigo-200">
              Datos y Analitica
            </h3>
            <div class="mt-2 flex flex-wrap gap-2">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/postgresql.svg" alt="PostgreSQL" class="h-3.5 w-3.5" loading="lazy" />PostgreSQL</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/mongodb.svg" alt="MongoDB" class="h-3.5 w-3.5" loading="lazy" />MongoDB</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/elasticsearch.svg" alt="Elasticsearch" class="h-3.5 w-3.5" loading="lazy" />Elasticsearch</span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200"><img src="/icons/jupyter.svg" alt="Jupyter" class="h-3.5 w-3.5" loading="lazy" />Jupyter</span>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  (function () {
    function initTechModal() {
      var modal = document.getElementById('tech-modal');
      var openBtn = document.querySelector('[data-open-tech-modal]');
      var closeBtn = document.querySelector('[data-close-tech-modal]');
      var backdrop = modal ? modal.querySelector('[data-tech-modal-backdrop]') : null;
      if (!modal || !openBtn || !closeBtn || !backdrop) return;

      function openModal() {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
      }

      openBtn.addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);
      backdrop.addEventListener('click', closeModal);

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
          closeModal();
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTechModal);
    } else {
      initTechModal();
    }
  })();
</script>
