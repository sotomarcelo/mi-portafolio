---
import Navbar from './components/Navbar.astro';
---

<html lang="es" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Mi Portafolio</title>
    <script>
      // Prevent FOUC: set data-theme before first paint
      (function () {
        try {
          var stored = localStorage.getItem('color-theme');
          if (
            stored === 'dark' ||
            (stored === null && window.matchMedia('(prefers-color-scheme: dark)').matches)
          ) {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (e) {
          if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        }
      })();
    </script>
  </head>
  <body class="bg-base-100 text-base-content min-h-screen">
    <Navbar />
    <script>
      // Theme toggle handler
      (function () {
        function initThemeToggle() {
          const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
          const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
          const themeToggleBtn = document.getElementById('theme-toggle');
          if (!themeToggleDarkIcon || !themeToggleLightIcon || !themeToggleBtn) return;

          var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          if (isDark) {
            themeToggleLightIcon.classList.remove('hidden');
          } else {
            themeToggleDarkIcon.classList.remove('hidden');
          }

          themeToggleBtn.addEventListener('click', function () {
            themeToggleDarkIcon!.classList.toggle('hidden');
            themeToggleLightIcon!.classList.toggle('hidden');

            var current = document.documentElement.getAttribute('data-theme');
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            try {
              localStorage.setItem('color-theme', next);
            } catch (e) {}
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initThemeToggle);
        } else {
          initThemeToggle();
        }
      })();
    </script>
    <script>
      // Mobile navbar toggle
      (function () {
        function initNavbarToggle() {
          const toggleBtn = document.querySelector('[data-collapse-toggle="navbar-sticky"]');
          const menu = document.getElementById('navbar-sticky');
          if (!toggleBtn || !menu) return;

          toggleBtn.addEventListener('click', function () {
            var isHidden = menu!.classList.contains('hidden');
            menu!.classList.toggle('hidden');
            toggleBtn!.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
          });

          var navLinks = menu.querySelectorAll('a[href]');
          navLinks.forEach(function (link) {
            link.addEventListener('click', function () {
              if (window.innerWidth < 768) {
                menu!.classList.add('hidden');
                toggleBtn!.setAttribute('aria-expanded', 'false');
              }
            });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initNavbarToggle);
        } else {
          initNavbarToggle();
        }
      })();
    </script>
    <slot />
  </body>
</html>
