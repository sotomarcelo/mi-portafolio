---
const pathname = Astro.url.pathname;

const isInicio = pathname === '/' || pathname === '/inicio' || pathname === '/home';
const isExperiencia = pathname.startsWith('/experiencia');
const isProyectos = pathname.startsWith('/proyectos');

const linkClass = (isActive: boolean) =>
  `block py-2 px-3 rounded-md md:p-0 transition-colors ${
    isActive ? 'text-primary font-bold' : 'text-base-content hover:text-primary font-medium'
  }`;
---

<nav
  class="navbar bg-base-100/80 backdrop-blur-md fixed w-full z-20 top-0 start-0 border-b border-base-300 shadow-sm"
>
  <div class="max-w-7xl flex items-center justify-between mx-auto p-4 w-full">
    <!-- Left: toggle and mobile menu button -->
    <div class="flex items-center space-x-3 md:order-1">
      <button
        id="theme-toggle"
        type="button"
        class="btn btn-ghost btn-sm btn-circle no-focus-ring"
        aria-label="Toggle dark mode"
      >
        <svg
          id="theme-toggle-dark-icon"
          class="hidden w-5 h-5"
          fill="currentColor"
          viewBox="0 0 20 20"
          xmlns="http://www.w3.org/2000/svg"
          ><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg
        >
        <svg
          id="theme-toggle-light-icon"
          class="hidden w-5 h-5"
          fill="currentColor"
          viewBox="0 0 20 20"
          xmlns="http://www.w3.org/2000/svg"
          ><path
            d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
            fill-rule="evenodd"
            clip-rule="evenodd"></path></svg
        >
      </button>

      <button
        data-collapse-toggle="navbar-sticky"
        type="button"
        class="btn btn-ghost btn-sm btn-square md:hidden"
        aria-controls="navbar-sticky"
        aria-expanded="false"
      >
        <span class="sr-only">Open main menu</span>
        <svg
          class="w-5 h-5"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 17 14"
        >
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M1 1h15M1 7h15M1 13h15"></path>
        </svg>
      </button>
    </div>

    <!-- Center: nav links -->
    <div class="flex-1 flex justify-center md:order-2">
      <div
        class="items-center justify-center hidden w-full md:flex md:w-auto absolute left-0 top-full md:static md:top-auto"
        id="navbar-sticky"
      >
        <ul
          class="flex flex-col p-4 md:p-0 font-medium rounded-b-lg bg-base-100 border-b border-base-300 md:border-0 shadow-lg md:shadow-none md:space-x-8 rtl:space-x-reverse md:flex-row md:bg-transparent"
        >
          <li>
            <a
              href="/inicio"
              class={linkClass(isInicio)}
              aria-current={isInicio ? 'page' : undefined}>Inicio</a
            >
          </li>
          <li>
            <a
              href="/experiencia"
              class={linkClass(isExperiencia)}
              aria-current={isExperiencia ? 'page' : undefined}>Experiencia</a
            >
          </li>
          <li>
            <a
              href="/proyectos"
              class={linkClass(isProyectos)}
              aria-current={isProyectos ? 'page' : undefined}>Proyectos</a
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Right: Descargar CV -->
    <div class="flex items-center md:order-3">
      <a href="/experiencia" class="btn btn-primary btn-xs sm:btn-sm">Ver CV</a>
    </div>
  </div>
</nav>
