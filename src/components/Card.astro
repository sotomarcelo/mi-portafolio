---
export interface Props {
  id?: string;
  title?: string;
  colorClass?: string;
  content?: string;
  showButton?: boolean;
  buttonText?: string;
  buttonHref?: string;
}
const {
  id,
  title = '',
  colorClass = '',
  content = '',
  showButton = false,
  buttonText = 'Ver más',
  buttonHref = '#',
  ...rest
} = Astro.props;
---

<div
  {...rest}
  id={id}
  class={`card bg-base-100 shadow-md border border-base-300 relative h-full w-full p-4 flex flex-col justify-between ${colorClass}`}
>
  <!-- Inner content wrapper -->
  <div class="card-inner">
    <div>
      {
        title ? (
          <div class="mb-2 flex items-center justify-between gap-2">
            <h5 class="text-xl font-bold tracking-tight text-base-content">{title}</h5>
            <slot name="title-action" />
          </div>
        ) : null
      }
      {content ? <p class="mb-3 font-normal text-base-content/70">{content}</p> : null}
      <slot />
    </div>
    {
      showButton && (
        <a href={buttonHref} class="btn btn-primary btn-sm mt-2">
          {buttonText}
        </a>
      )
    }
  </div>

  <!-- Named slot for overlays that must not be blurred (e.g., hover CTA) -->
  <slot name="overlay" />
</div>
