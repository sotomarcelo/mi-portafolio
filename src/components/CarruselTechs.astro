---
import { Icon } from 'astro-icon/components';
const iconList = [
  { name: 'react', file: 'react.svg', color: 'text-sky-400' },
  { name: 'nextjs', file: 'nextjs.svg', color: 'text-base-content' },
  { name: 'astro', file: 'astro.svg', color: 'text-orange-400' },
  { name: 'python', file: 'python.svg', color: 'text-yellow-400' },
  { name: 'mongodb', file: 'mongodb.svg', color: 'text-green-500' },
  { name: 'postgresql', file: 'postgresql.svg', color: 'text-blue-500' },
  { name: 'django', file: 'django.svg', color: 'text-green-500' },
  { name: 'html5', file: 'html5.svg', color: 'text-orange-400' },
  { name: 'css3', file: 'css3.svg', color: 'text-blue-500' },
  { name: 'tailwindcss', file: 'tailwindcss.svg', color: 'text-sky-400' },
  {
    name: 'elasticsearch',
    file: 'elasticsearch.svg',
    color: 'text-orange-400',
  },
  { name: 'jupyter', file: 'jupyter.svg', color: 'text-orange-400' },
];
---

<div
  class="overflow-hidden w-full py-2 flex items-center justify-center"
  style="height:4.5rem;"
>
  <div class="relative w-full h-16">
    <div
      class="absolute top-0 left-0 flex animate-marquee gap-8 text-3xl sm:text-4xl whitespace-nowrap w-max"
    >
      {
        [0, 1, 2].map(() =>
          iconList.map((item) => (
            <div
              class="hover:scale-110 transition-transform flex items-center justify-center "
              style="min-width:3.5rem;"
            >
              {item.file ? (
                <img
                  src={`/icons/${item.file}`}
                  alt={item.name}
                  class={`w-10 h-10 sm:w-12 sm:h-12 ${item.color}`}
                  loading="lazy"
                />
              ) : (
                <Icon name={item.name} class={`w-10 h-10 sm:w-12 sm:h-12 ${item.color}`} />
              )}
            </div>
          ))
        )
      }
    </div>
  </div>
</div>

<style is:global>
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-33.333%);
    }
  }
  .animate-marquee {
    animation: marquee 28s linear infinite;
  }
</style>
